# API Keys for Neural Hub v3
# Rename this file to .env and fill in your keys

# Official Google Cloud Translation API Key
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API Key (for the Claude-powered engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backend Port (Default: 24081)
PORT=24081
